PORT=5000

# MongoDB Atlas — mongodb.com/atlas (free cluster)
# Format: mongodb+srv://username:password@cluster.mongodb.net/nestway
MONGO_URI=/////

# OpenWeatherMap — openweathermap.org/api (free tier)
OPENWEATHER_API_KEY=your_key_here

# RapidAPI — rapidapi.com (trains + flights)
RAPIDAPI_KEY=your_key_here

# Google Maps
GOOGLE_MAPS_API_KEY=your_key_here

# Admin panel — change both of these before deploying!
ADMIN_SECRET=nestway-secret-change-in-prod
ADMIN_PASSWORD=nestway-admin-2024

# Set to false once MongoDB is connected
USE_MOCK_DATA=true
