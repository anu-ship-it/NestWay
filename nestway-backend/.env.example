# ───────────────────────────────────────────
#  NestWay Backend — Environment Variables
#  Copy this file to .env and fill in your keys
# ───────────────────────────────────────────

PORT=5000

# OpenWeatherMap — openweathermap.org/api (free tier)
OPENWEATHER_API_KEY=your_key_here

# RapidAPI — rapidapi.com (used for train + flight data)
RAPIDAPI_KEY=your_key_here

# Google Maps — console.cloud.google.com (for distance/maps)
GOOGLE_MAPS_API_KEY=your_key_here

# MongoDB Atlas — mongodb.com/atlas (free cluster)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/nestway

# Leave these as mock until you get real API access
USE_MOCK_DATA=true
